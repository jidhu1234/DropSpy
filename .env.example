# ─── WinningHunter — Environment Variables ───────────────────────────────────
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/winninghunter

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...      # $49/mo Pro plan price ID
STRIPE_AGENCY_PRICE_ID=price_...   # $149/mo Agency plan price ID

# Facebook Ad Library API — get from https://developers.facebook.com
# Create an app → Marketing API → generate a long-lived token
FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# AliExpress Affiliate API — get from https://portals.aliexpress.com
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_SECRET=your_secret

# Frontend URL (for Stripe redirect)
FRONTEND_URL=https://yourdomain.com

# ─── Frontend .env (put in /frontend/.env) ───────────────────────────────────
VITE_API_URL=http://localhost:3001
